# Server Configuration
PORT=3000
NODE_ENV=development # development, test, or production

# Security
API_KEY=your-secret-api-key-here
SESSION_SECRET=your-session-secret-here
CSRF_SECRET=your-csrf-secret-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX=100           # Maximum requests per window
RATE_LIMIT_SKIP_TRUSTED=false # Set to true to skip rate limiting for trusted IPs

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_TLS=false              # Set to true for secure Redis connections

# Session Configuration
SESSION_NAME=sessionId
SESSION_COOKIE_SECURE=true   # Always true in production for security
SESSION_COOKIE_MAX_AGE=1800000 # 30 minutes in milliseconds
SESSION_COOKIE_SAME_SITE=strict # Strict same-site policy
SESSION_COOKIE_HTTP_ONLY=true  # Prevent JavaScript access
SESSION_SAVE_UNINITIALIZED=true # Save new sessions
SESSION_RESAVE=true           # Resave unchanged sessions

# CORS Configuration
CORS_ENABLED=false           # Disabled by default for security
CORS_ORIGIN=                 # Empty to disable CORS
CORS_METHODS=                # Empty to disable CORS methods
CORS_ALLOWED_HEADERS=        # Empty to disable CORS headers

# Logging
LOG_LEVEL=info              # debug, info, warn, error
LOG_FORMAT=json            # json or text
ERROR_LOGGING=true         # Enable detailed error logging

# Security Headers
STRICT_SECURITY_HEADERS=true  # Enable strict security headers
CSP_REPORT_URI=/csp-report   # URI for CSP violation reports
CSP_DEFAULT_SRC="'self'"     # Default CSP source
CSP_SCRIPT_SRC="'self'"      # Script CSP source
CSP_STYLE_SRC="'self'"       # Style CSP source
CSP_IMG_SRC="'self' data: https:" # Image CSP source
HSTS_MAX_AGE=31536000       # 1 year HSTS max age
HSTS_INCLUDE_SUBDOMAINS=true # Include subdomains in HSTS
HSTS_PRELOAD=true           # Enable HSTS preloading
X_FRAME_OPTIONS=DENY        # Prevent clickjacking
REFERRER_POLICY=strict-origin-when-cross-origin # Strict referrer policy

# Test Configuration
TEST_API_KEY=test-api-key
TEST_RATE_LIMIT_WINDOW=1000    # 1 second for faster testing
TEST_RATE_LIMIT_MAX=2          # 2 requests per window for testing
TEST_SESSION_SECRET=test-secret # Session secret for tests
TEST_CSRF_SECRET=test-csrf     # CSRF secret for tests
TEST_STORE=memory             # Use memory store in tests
TEST_COVERAGE_THRESHOLD=80    # Target test coverage percentage
TEST_SECURITY_HEADERS=true    # Enable security headers in tests
TEST_SECURE_COOKIES=false     # Disable secure cookies in tests

# Documentation
SWAGGER_ENABLED=true       # Enable Swagger documentation
SWAGGER_USERNAME=admin     # Basic auth for Swagger UI
SWAGGER_PASSWORD=password  # Basic auth for Swagger UI

# Monitoring
ENABLE_METRICS=true        # Enable performance metrics
METRICS_PORT=9090         # Port for metrics endpoint

# Development Only (remove in production)
DISABLE_SECURITY=false     # Never set to true in production
DEBUG_MODE=false          # Enable debug logging